# Google AI MCP — backend
FROM python:3.12-slim AS backend

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock README.md ./
COPY src ./src

RUN uv sync --frozen --no-dev

ENV PYTHONUNBUFFERED=1
ENV HOST=0.0.0.0
ENV PORT=11014

EXPOSE 11014

CMD ["uv", "run", "uvicorn", "google_ai_mcp.server:app", "--host", "0.0.0.0", "--port", "11014"]
